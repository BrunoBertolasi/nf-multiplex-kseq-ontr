/*
 * Module-specific configuration
 * Defines resource requirements and options for each process
 */

process {
    // Generate candidate primers
    withName: 'GENERATE_PRIMERS' {
        label = 'process_medium'
        publishDir = [
            path: { "${params.outdir}/01_candidates" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    // Filter primers by properties
    withName: 'FILTER_PRIMERS' {
        label = 'process_low'
        publishDir = [
            path: { "${params.outdir}/02_filtered" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    // Count binding sites
    withName: 'COUNT_SITES' {
        label = 'process_high'
        publishDir = [
            path: { "${params.outdir}/03_binding_sites" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    // Pair primers
    withName: 'PAIR_PRIMERS' {
        label = 'process_medium'
        publishDir = [
            path: { "${params.outdir}/04_pairs" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    // Find compatible sets
    withName: 'FIND_COMPATIBLE_SETS' {
        label = 'process_high'
        publishDir = [
            path: { "${params.outdir}/05_compatible_sets" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    // Optimize coverage
    withName: 'OPTIMIZE_COVERAGE' {
        label = 'process_medium'
        publishDir = [
            path: { "${params.outdir}/06_optimized" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    // Validate primers
    withName: 'VALIDATE_PRIMERS' {
        label = 'process_medium'
        publishDir = [
            path: { "${params.outdir}/07_validation" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
}
